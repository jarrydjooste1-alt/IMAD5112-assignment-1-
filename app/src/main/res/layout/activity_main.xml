<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="@drawable/gradient_background"
    tools:context=".MainActivity">

<!--   App Title -->
<!-- This is the app title displayed at the top of the screen. You can change the text and style as needed. -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=" Social Spark "
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="32dp"
        android:shadowColor="@android:color/black"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Connect with others, one spark at a time!"
        android:textSize="16sp"
        android:textColor="#E0E0E0"
        android:gravity="center"
        android:layout_marginBottom="48dp" />

    <!-- Input Field Label -->
<!--    This is the label for the time input field. You can change the text and style as needed. -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="What time is it?"
        android:textSize="18sp"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:layout_gravity="start" />

    <!-- Time Input Field -->
    <EditText
        android:id="@+id/etTimeOfDay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g., Morning, Afternoon, Dinner, Night..."
        android:padding="16dp"
        android:textSize="16sp"
        android:background="@drawable/edit_text_background"
        android:inputType="text"
        android:maxLines="1"
        android:layout_marginBottom="24dp" />

    <!-- Get Suggestion Button -->
<!--    This is the button that triggers the suggestion generation. You can change the text and style as needed. -->
    <Button
        android:id="@+id/btnGetSuggestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=" Get Social Spark "
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="12dp"
        android:background="@drawable/button_background"
        android:textColor="@android:color/white"
        android:layout_marginBottom="16dp" />

    <!-- Reset Button -->
<!--    This is the button that resets the input fields and suggestion. You can change the text and style if you choose to do so. -->
    <Button
        android:id="@+id/btnReset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=" Reset"
        android:textSize="16sp"
        android:padding="12dp"
        android:background="@drawable/button_background_secondary"
        android:textColor="@android:color/white"
        android:layout_marginBottom="32dp" />

    <!-- Suggestion Display Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Your Spark Idea"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FF6B6B"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvSuggestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your social spark will appear here! "
                android:textSize="16sp"
                android:textColor="#333333"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>